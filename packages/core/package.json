{
  "name": "@react-insight/core",
  "version": "0.1.0",
  "description": "TypeScript-first plugin runtime powering React Insight.",
  "keywords": [
    "react",
    "react-insight",
    "plugin",
    "runtime",
    "typescript",
    "debugging",
    "inspection",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afraz-saeed1986/react-insight.git"
  },
  "homepage": "https://github.com/afraz-saeed1986/react-insight",
  "bugs": {
    "url": "https://github.com/afraz-saeed1986/react-insight/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@react-insight/eslint-config": "workspace:*",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
