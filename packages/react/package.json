{
  "name": "@react-insight/react",
  "version": "0.1.0",
  "description": "React integration for React Insight",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@react-insight/core": "workspace:*"
  },
  "devDependencies": {
    "@react-insight/eslint-config": "workspace:*",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.8.0",
    "jsdom": "^26.1.0",
    "vitest": "^4.1.10"
  }
}
